# Copy this file to .env and fill in your own values.

# Gemini API key for Google Gemini model access
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-1.5-mini

# Local fallback model if GEMINI_API_KEY is not provided
HF_MODEL_NAME=google/flan-t5-small

# Use CUDA/GPU if available (set to 1 to enable)
USE_CUDA=0

# Kafka settings
KAFKA_HOST=localhost
KAFKA_PORT=9092
